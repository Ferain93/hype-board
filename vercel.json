{
  "version": 2,
  "builds": [
    {
      "src": "hype-backend/src/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "hype-frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "hype-backend/src/main.ts"
    },
    {
      "src": "/(.*)",
      "dest": "hype-frontend/$1"
    }
  ]
}